# Maintained from the postmarketOS firmware-oneplus-sdm845 package.
# Reference:
# https://gitlab.postmarketos.org/postmarketOS/pmaports/-/raw/master/device/community/firmware-oneplus-sdm845/APKBUILD

pkgname=firmware-oneplus-sdm845
pkgver=10
pkgrel=1
pkgdesc="OnePlus 6/6T SDM845 base firmware payload"
arch=('any')
url="https://gitlab.com/sdm845-mainline/firmware-oneplus-sdm845"
license=('custom:proprietary')
depends=('linux-firmware-qcom')
options=('!strip' '!debug')

_commit="176ca713448c5237a983fb1f158cf3a5c251d775"
_pmos_device_url="https://gitlab.postmarketos.org/postmarketOS/pmaports/-/raw/master/device/community/firmware-oneplus-sdm845"

source=(
  "$pkgname-$_commit.tar.gz::$url/-/archive/$_commit/$pkgname-$_commit.tar.gz"
  "firmware.files::$_pmos_device_url/firmware.files"
)
sha512sums=(
  '68ecc3cec0458e5c7a0c6e2d1b0da72df324b48e1283e6e0ebc3c1713e8b721386e2554edf48fd559a8b8a40b54f3d4046ba2e484342ff4d5c69baf0839a800e'
  '23e4ea891f688bf5669e4b8479aab06b56c5478429b759c22fa417e1ad09cb413e55856140b456c6b676b8920ecec40aa0215d8fd61a23ac2c5c02240552f247'
)

package() {
  local rel target
  cd "$srcdir/$pkgname-$_commit"

  while IFS= read -r rel || [[ -n "$rel" ]]; do
    [[ -z "$rel" ]] && continue
    rel="${rel#./}"

    case "$rel" in
      lib/firmware/*)
        target="usr/$rel"
        ;;
      *)
        target="$rel"
        ;;
    esac

    install -Dm644 "$rel" "$pkgdir/$target"
  done < "$srcdir/firmware.files"
}
