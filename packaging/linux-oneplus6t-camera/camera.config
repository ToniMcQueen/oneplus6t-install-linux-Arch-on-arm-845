# Camera framework and Qualcomm SDM845 CAMSS.
CONFIG_MEDIA_SUPPORT=m
CONFIG_MEDIA_SUPPORT_FILTER=y
CONFIG_MEDIA_CAMERA_SUPPORT=y
CONFIG_MEDIA_PLATFORM_SUPPORT=y
CONFIG_VIDEO_DEV=m
CONFIG_MEDIA_CONTROLLER=y
CONFIG_VIDEO_V4L2_I2C=y
CONFIG_VIDEO_V4L2_SUBDEV_API=y
CONFIG_V4L2_FWNODE=m
CONFIG_V4L2_ASYNC=m
CONFIG_V4L2_CCI=m
CONFIG_V4L2_CCI_I2C=m
CONFIG_MEDIA_PLATFORM_DRIVERS=y
CONFIG_V4L_PLATFORM_DRIVERS=y
CONFIG_VIDEO_QCOM_CAMSS=m

# OnePlus 6/6T sensors carried by the pinned SDM845 camera branch.
CONFIG_VIDEO_IMX371=m
CONFIG_VIDEO_IMX376=m
CONFIG_VIDEO_IMX519=m

# OnePlus 6/6T NFC controller.
# Stock Android exposes NXP NFC over I2C at 0x28 as /dev/pn553. The Linux
# device tree already exposes compatible "nxp,nxp-nci-i2c", so build the
# matching kernel modules instead of the unrelated Samsung S3FWRN5-only path.
CONFIG_NFC=m
CONFIG_NFC_NCI=m
CONFIG_NFC_NXP_NCI=m
CONFIG_NFC_NXP_NCI_I2C=m

# The PMOS base config builds CIFS/SMB into vmlinux. On this x86_64 host
# clang/LLVM 22 lowers part of fs/smb/client/smb2pdu.o to a wcslen reference,
# which the kernel does not provide. The phone image does not need in-kernel
# SMB/CIFS for camera/NFC bringup, so keep it out of this candidate kernel.
# CONFIG_CIFS is not set
