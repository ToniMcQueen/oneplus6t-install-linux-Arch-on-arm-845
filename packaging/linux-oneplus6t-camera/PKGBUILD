# Maintainer: LinuxPhone project
# Camera branch provenance is recorded in camera-series.tsv.

pkgname=linux-oneplus6t-camera
pkgver=6.13.0
pkgrel=12
pkgdesc="Pinned SDM845 camera kernel for the OnePlus 6 and 6T"
arch=('aarch64')
url="https://gitlab.com/sdm845-mainline/linux"
license=('GPL-2.0-only')
provides=('linux-aarch64')
conflicts=('linux-aarch64')
replaces=('linux-aarch64')
makedepends=('bc' 'bison' 'cpio' 'flex' 'gzip' 'kmod' 'openssl' 'pahole' 'perl' 'python' 'rsync' 'tar' 'zstd')
options=('!strip')

_commit=26f9dfad4030de634dbf50f398f95281c29c3965
_pmaports_commit=817ed870e92a64963d926354fb74c75090811fcc
_config="config-postmarketos-qcom-sdm845.aarch64"
_srcdir="linux-${_commit}"

source=(
  "${pkgname}-${_commit}.tar.gz::https://gitlab.com/sdm845-mainline/linux/-/archive/${_commit}/linux-${_commit}.tar.gz"
  "${_config}::https://gitlab.com/postmarketOS/pmaports/-/raw/${_pmaports_commit}/device/community/linux-postmarketos-qcom-sdm845/${_config}"
  'camera.config'
  'hibernate.config'
  'camera-series.tsv'
  '0001-media-qcom-camss-set-csid-cphy-bit.patch'
  '0002-media-qcom-camss-bound-sdm845-cphy-lane-table.patch'
  '0003-media-qcom-camss-add-oneplus6t-imx519-diagnostics.patch'
  '0004-media-qcom-camss-add-oneplus6t-cphy-lab-overrides.patch'
  '0005-media-i2c-imx519-add-oneplus6t-stream-readbacks.patch'
  '0007-media-qcom-camss-add-oneplus6t-runtime-state-dumps.patch'
  '0008-media-qcom-camss-log-oneplus6t-csiphy-state.patch'
)
