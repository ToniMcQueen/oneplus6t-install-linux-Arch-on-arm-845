_kernel_make_args() {
  local -n _out="$1"
  _out=(ARCH=arm64)

  if [[ "${ONEPLUS6T_CAMERA_HOST_LLVM:-0}" == "1" ]]; then
    _out+=(LLVM=1 LLVM_IAS=1)
  fi
}

_merge_oneplus6t_config() {
  local -n _make_args="$1"

  scripts/kconfig/merge_config.sh -m .config \
    "${srcdir}/camera.config" \
    "${srcdir}/hibernate.config"
  make "${_make_args[@]}" olddefconfig
}

prepare() {
  cd "${_srcdir}"
  local make_args
  _kernel_make_args make_args

  patch -Np1 -i "${srcdir}/0001-media-qcom-camss-set-csid-cphy-bit.patch"
  patch -Np1 -i "${srcdir}/0002-media-qcom-camss-bound-sdm845-cphy-lane-table.patch"
  patch -Np1 -i "${srcdir}/0003-media-qcom-camss-add-oneplus6t-imx519-diagnostics.patch"
  patch -Np1 -i "${srcdir}/0004-media-qcom-camss-add-oneplus6t-cphy-lab-overrides.patch"
  patch -Np1 -i "${srcdir}/0005-media-i2c-imx519-add-oneplus6t-stream-readbacks.patch"
  patch -Np1 -i "${srcdir}/0007-media-qcom-camss-add-oneplus6t-runtime-state-dumps.patch"
  patch -Np1 -i "${srcdir}/0008-media-qcom-camss-log-oneplus6t-csiphy-state.patch"
  cp "${srcdir}/${_config}" .config
  _merge_oneplus6t_config make_args
}

build() {
  cd "${_srcdir}"
  local make_args
  _kernel_make_args make_args
  _merge_oneplus6t_config make_args

  make \
    "${make_args[@]}" \
    KBUILD_BUILD_USER=linuxphone \
    KBUILD_BUILD_HOST=reproducible \
    KBUILD_BUILD_TIMESTAMP="@${SOURCE_DATE_EPOCH:-0}" \
    KBUILD_BUILD_VERSION="${pkgrel}-oneplus6t-camera" \
    -j"${MAKEFLAGS_NPROC:-$(nproc)}"
}

package() {
  cd "${_srcdir}"

  local kernelrelease
  local make_args
  _kernel_make_args make_args
  kernelrelease="$(make -s "${make_args[@]}" kernelrelease)"

  if [[ -f arch/arm64/boot/vmlinuz ]]; then
    install -Dm644 arch/arm64/boot/vmlinuz \
      "${pkgdir}/boot/vmlinuz-oneplus6t-camera"
  elif [[ -f arch/arm64/boot/Image.gz ]]; then
    install -Dm644 arch/arm64/boot/Image.gz \
      "${pkgdir}/boot/vmlinuz-oneplus6t-camera"
  elif [[ -f arch/arm64/boot/Image ]]; then
    install -d "${pkgdir}/boot"
    gzip -n -9 -c arch/arm64/boot/Image > \
      "${pkgdir}/boot/vmlinuz-oneplus6t-camera"
    chmod 0644 "${pkgdir}/boot/vmlinuz-oneplus6t-camera"
  else
    echo "No usable arm64 kernel image was produced." >&2
    find arch/arm64/boot -maxdepth 1 -type f -printf '%f\n' >&2
    return 1
  fi
  install -Dm644 arch/arm64/boot/dts/qcom/sdm845-oneplus-fajita.dtb \
    "${pkgdir}/boot/dtbs/qcom/sdm845-oneplus-fajita.dtb"

  make \
    "${make_args[@]}" \
    INSTALL_MOD_PATH="${pkgdir}/usr" \
    INSTALL_MOD_STRIP=1 \
    modules_install

  rm -f \
    "${pkgdir}/usr/lib/modules/${kernelrelease}/build" \
    "${pkgdir}/usr/lib/modules/${kernelrelease}/source"

  install -Dm644 include/config/kernel.release \
    "${pkgdir}/usr/share/linux-oneplus6t-camera/kernel.release"
  install -Dm644 "${srcdir}/camera.config" \
    "${pkgdir}/usr/share/linux-oneplus6t-camera/camera.config"
  install -Dm644 "${srcdir}/hibernate.config" \
    "${pkgdir}/usr/share/linux-oneplus6t-camera/hibernate.config"
  install -Dm644 "${srcdir}/camera-series.tsv" \
    "${pkgdir}/usr/share/linux-oneplus6t-camera/camera-series.tsv"
  printf '%s\n' "${_commit}" > \
    "${pkgdir}/usr/share/linux-oneplus6t-camera/source-commit"
}
