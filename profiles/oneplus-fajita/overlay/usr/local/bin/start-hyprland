#!/usr/bin/env bash
set -euo pipefail

export LANG="${LANG:-C.UTF-8}"
export LC_CTYPE="${LC_CTYPE:-C.UTF-8}"
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
export XDG_SESSION_TYPE=wayland
export XDG_CURRENT_DESKTOP=Hyprland
export XDG_SESSION_DESKTOP=Hyprland
hypr_conf_dir="${HOME:-/home/alarm}/.config/hypr/conf.d"
hyperrotation_plugin="${HOME:-/home/alarm}/.config/hypr/plugins/hyperrotation.so"
hyperrotation_runtime_conf="$hypr_conf_dir/09-oneplus6t-hyperrotation-runtime.conf"
log() { printf 'start-hyprland: %s\n' "$*" >&2; }

hyprland_launcher="${HYPRLAND_LAUNCHER:-/usr/bin/start-hyprland}"
hyprland_bin="${HYPRLAND_BIN:-/usr/bin/Hyprland}"
script_bin="$(readlink -f "$0" 2>/dev/null || printf '%s' "$0")"
resolved_launcher=""
launcher_exec=""

if [[ -x "$hyprland_launcher" ]]; then
  if launcher_real="$(command -v "$hyprland_launcher" 2>/dev/null)"; then
    resolved_launcher="$(readlink -f "$launcher_real" 2>/dev/null || printf '%s' "$launcher_real")"
  else
    resolved_launcher="$hyprland_launcher"
  fi
fi

if [[ -n "$resolved_launcher" && "$resolved_launcher" != "$script_bin" ]]; then
  launcher_exec="$hyprland_launcher"
  log "external launcher detected: $launcher_exec"
fi

if [[ ! -d "$XDG_RUNTIME_DIR" || ! -w "$XDG_RUNTIME_DIR" ]]; then
  export XDG_RUNTIME_DIR="/tmp/runtime-$(id -u)"
  mkdir -p "$XDG_RUNTIME_DIR"
  chmod 0700 "$XDG_RUNTIME_DIR"
fi
touch "$XDG_RUNTIME_DIR/oneplus6t-desktop-launching" 2>/dev/null || true

mkdir -p "$hypr_conf_dir"
if [[ -f "$hyperrotation_plugin" ]]; then
  cat > "$hyperrotation_runtime_conf" <<EOF
# Generated by start-hyprland only when the ABI-local plugin exists.
plugin = $hyperrotation_plugin

plugin:rotation:output = DSI-1
plugin:rotation:mode = 1080x2340@60
plugin:rotation:position = 0x0
plugin:rotation:scale = 1
plugin:rotation:touch_transform = -1
plugin:rotation:mute_notifications = 0
EOF
else
  rm -f "$hyperrotation_runtime_conf"
  printf 'start-hyprland: HyperRotation plugin missing at %s; booting without plugin until first-boot build finishes\n' "$hyperrotation_plugin" >&2
fi

if [[ -n "$launcher_exec" ]]; then
  log "launching external launcher ${launcher_exec}"
  exec "$launcher_exec" --path "$hyprland_bin"
fi

if [[ -x "$hyprland_bin" ]]; then
  log "launcher is self; starting Hyprland binary ${hyprland_bin}"
  exec "$hyprland_bin"
fi

log "hyprland binary not found at $hyprland_bin"
exit 1
