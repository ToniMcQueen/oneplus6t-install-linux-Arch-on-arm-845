# OnePlus 6T / fajita Arch Linux ARM image profile.

DEVICE_NAME="OnePlus 6T"
DEVICE_CODENAME="oneplus-fajita"
FASTBOOT_PRODUCT="sdm845"

# Official Arch Linux ARM generic aarch64 rootfs tarball.
# The builder downloads this at build time unless ARCH_ROOTFS_TARBALL is set.
ARCHLINUXARM_ROOTFS_URL="${ARCHLINUXARM_ROOTFS_URL:-http://os.archlinuxarm.org/os/ArchLinuxARM-aarch64-latest.tar.gz}"

# Image identity. The boot image cmdline points at this root UUID.
ROOT_LABEL="${ROOT_LABEL:-archroot}"
ROOT_UUID="${ROOT_UUID:-8f3b0c30-9845-451d-aed4-7e80541a0d29}"
ROOT_DEVICE="${ROOT_DEVICE:-/dev/sda17}"
ROOT_IMAGE_SIZE="${ROOT_IMAGE_SIZE:-8G}"
# Fallback used only when the host fastboot build cannot capture getvar output.
# Observed on the 128GB OnePlus 6T test device:
#   fastboot getvar partition-size:userdata -> 0x1B800BB000
# Override this for a different storage variant.
FASTBOOT_USERDATA_SIZE_FALLBACK_HEX="${FASTBOOT_USERDATA_SIZE_FALLBACK_HEX:-0x1B800BB000}"
# Avoid host btrfs-progs enabling very new filesystem features by default.
# The PMOS SDM845 kernel/initramfs path should see a conservative rootfs.
BTRFS_MKFS_FEATURES="${BTRFS_MKFS_FEATURES:-^block-group-tree}"

# PMOS SDM845 boot artifacts captured from the working phone state.
PMOS_BOOT_DIR="${PMOS_BOOT_DIR:-$ROOT_DIR/vendor/pmos-oneplus-fajita/boot}"
PMOS_KERNEL="${PMOS_KERNEL:-vmlinuz}"
PMOS_DTB="${PMOS_DTB:-sdm845-oneplus-fajita.dtb}"
PMOS_INITRAMFS="${PMOS_INITRAMFS:-initramfs}"
PMOS_INITRAMFS_EXTRA="${PMOS_INITRAMFS_EXTRA:-initramfs-extra}"
# Embed initramfs-extra into the Android ramdisk and patch PMOS /init to use it
# before looking for a separate boot partition. This keeps the public image
# self-contained on the plain-Btrfs /dev/sda17 layout.
PMOS_EMBED_INITRAMFS_EXTRA="${PMOS_EMBED_INITRAMFS_EXTRA:-1}"

# Boot kernel source:
#   pmos-snapshot  known-good PMOS 6.9 kernel/DTB recovery baseline
#   camera-package pinned SDM845 6.13 camera package from out/.../packages
#
# Keep the snapshot as the default until the camera candidate passes a full
# paired-image boot and parity report on physical hardware.
BOOT_KERNEL_SOURCE="${BOOT_KERNEL_SOURCE:-pmos-snapshot}"
CAMERA_KERNEL_PACKAGE_GLOB="${CAMERA_KERNEL_PACKAGE_GLOB:-linux-oneplus6t-camera-*-aarch64.pkg.tar.*}"
CAMERA_PACKAGE_MANIFEST="${CAMERA_PACKAGE_MANIFEST:-$PROFILE_DIR/camera-packages.txt}"
if [[ "$BOOT_KERNEL_SOURCE" == "camera-package" ]]; then
  ENABLE_CAMERA_USERSPACE="${ENABLE_CAMERA_USERSPACE:-1}"
else
  ENABLE_CAMERA_USERSPACE="${ENABLE_CAMERA_USERSPACE:-0}"
fi

# Known-good Android boot image parameters for the OnePlus 6T PMOS v24.06 kernel.
BOOT_BASE="${BOOT_BASE:-0x00000000}"
BOOT_KERNEL_OFFSET="${BOOT_KERNEL_OFFSET:-0x00008000}"
BOOT_RAMDISK_OFFSET="${BOOT_RAMDISK_OFFSET:-0x01000000}"
BOOT_SECOND_OFFSET="${BOOT_SECOND_OFFSET:-0x00f00000}"
BOOT_TAGS_OFFSET="${BOOT_TAGS_OFFSET:-0x00000100}"
BOOT_PAGESIZE="${BOOT_PAGESIZE:-4096}"
BOOT_HEADER_VERSION="${BOOT_HEADER_VERSION:-0}"

# Keep both root hints in the boot image. PMOS init can use the Btrfs UUID,
# while /dev/sda17 remains the stable OnePlus 6T userdata fallback.
BOOT_CMDLINE="${BOOT_CMDLINE:-console=ttyMSM0,115200 rw earlycon loglevel=7 pmos.stowaway pmos_root_uuid=${ROOT_UUID} pmos_root=${ROOT_DEVICE} rootfstype=btrfs PMOS_NOSPLASH PMOS_NO_OUTPUT_REDIRECT console=tty1 audit=0}"

# Public builds should use SSH keys. For throwaway local test images only, set
# ALLOW_INSECURE_DEFAULT_PASSWORD=1 before running build-rootfs-image.sh.
# Root SSH/su and the alarm desktop account both use the familiar local dev
# password. Syslock, when enabled again later, keeps its own separate keypad PIN.
ALLOW_INSECURE_DEFAULT_PASSWORD="${ALLOW_INSECURE_DEFAULT_PASSWORD:-0}"
INSECURE_ROOT_PASSWORD="${INSECURE_ROOT_PASSWORD:-alarm}"
INSECURE_ALARM_PASSWORD="${INSECURE_ALARM_PASSWORD:-alarm}"

# Optional SSH key onboarding. Set one of these for local or CI builds:
#   SSH_AUTHORIZED_KEYS_FILE=/path/to/id_ed25519.pub
#   SSH_AUTHORIZED_KEYS_GLOB='/home/user/.ssh/*.pub'
#   SSH_AUTHORIZED_KEYS='ssh-ed25519 AAAA... comment'
#
# When keys are installed, password SSH login is disabled by default.
SSH_AUTHORIZED_KEYS_FILE="${SSH_AUTHORIZED_KEYS_FILE:-}"
SSH_AUTHORIZED_KEYS_GLOB="${SSH_AUTHORIZED_KEYS_GLOB:-}"
SSH_AUTHORIZED_KEYS="${SSH_AUTHORIZED_KEYS:-}"
DISABLE_SSH_PASSWORD_AUTH="${DISABLE_SSH_PASSWORD_AUTH:-1}"
INSTALL_ROOT_SSH_KEYS="${INSTALL_ROOT_SSH_KEYS:-0}"

# Install profiles/oneplus-fajita/packages.txt into the generated root image.
# Set INSTALL_PROFILE_PACKAGES=0 only for low-level boot debugging.
INSTALL_PROFILE_PACKAGES="${INSTALL_PROFILE_PACKAGES:-1}"

# Hexagon/SSC sensors use the PMOS-style OnePlus 6T boot timing by default:
# start hexagonrpcd-sdsp during sysinit, start iio-sensor-proxy later, and keep
# ADSP fallback units masked. Set this to 0 only for crashdump recovery images.
ENABLE_HEXAGON_SENSORS="${ENABLE_HEXAGON_SENSORS:-1}"

# Qualcomm remoteproc module loading is normally required for the modem,
# sensors, Wi-Fi, and camera experiments. Set this to 0 only for SSH-first
# crashdump recovery images.
ENABLE_QCOM_REMOTEPROC="${ENABLE_QCOM_REMOTEPROC:-1}"

# PMOS compatibility helpers normally provide the Qualcomm service shape used by
# radio/sensor bring-up. Set this to 0 only for SSH-first crashdump recovery
# images.
ENABLE_PMOS_COMPAT_UNITS="${ENABLE_PMOS_COMPAT_UNITS:-1}"

# Keep modem and Wi-Fi remoteproc out of the early sensor boot path, then bring
# them up through the delayed radio service after SDSP sensors are alive.
ENABLE_QCOM_RADIO="${ENABLE_QCOM_RADIO:-1}"

# Wi-Fi is loaded in a separate late service, after the modem/rmtfs path,
# NetworkManager, and first-boot UI build services settle. This matches the PMOS
# shape better than loading ath10k_snoc inside the radio service itself.
ENABLE_QCOM_WIFI="${ENABLE_QCOM_WIFI:-1}"

# Optional pinned source caches for phone UI components. These are public,
# source-available defaults; downstream builders can replace or remove them.
WVKBD_REF="${WVKBD_REF:-4fd182a58385b4754756e6dc66860e9ff601b3a1}"
WVKBD_SOURCE_CACHE_DIR="${WVKBD_SOURCE_CACHE_DIR:-$ROOT_DIR/vendor/wvkbd}"
HYPERROTATION_REF="${HYPERROTATION_REF:-38606861f25a2aec1eaefae38f3bcb8d0c332972}"
HYPERROTATION_SOURCE_CACHE_DIR="${HYPERROTATION_SOURCE_CACHE_DIR:-$ROOT_DIR/vendor/hyperrotation}"

# Optional local payload containing PMOS-compatible Qualcomm userspace helpers:
#   opt/pmos-compat/bin/tqftpserv
#   opt/pmos-compat/bin/pd-mapper
#   opt/pmos-compat/sbin/rmtfs
#   etc/systemd/system/pmos-compat-*.service
#
# The payload is intentionally not tracked in git because it contains opaque
# PMOS/Alpine binaries. Public installs can fetch it from the release input
# bundle into this repo-local path.
PMOS_COMPAT_PAYLOAD_DIR="${PMOS_COMPAT_PAYLOAD_DIR:-$ROOT_DIR/vendor/pmos-compat-payload}"

# Optional local PMOS hardware reference archive containing matching kernel
# modules and firmware. The builder extracts only into /usr/lib/{modules,firmware}
# so it does not disturb Arch's /lib -> /usr/lib symlink. Public installs can
# fetch it from the release input bundle into this repo-local path.
PMOS_HARDWARE_REFERENCE_TARBALL="${PMOS_HARDWARE_REFERENCE_TARBALL:-$ROOT_DIR/vendor/pmos-reference/pmos-v24.06-oneplus-fajita-hardware-reference.tar.zst}"
